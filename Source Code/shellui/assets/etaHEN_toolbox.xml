<?xml version="1.0" encoding="utf-8"?>
<package title="etaHEN Cheats Toolbox" version="1.0">
  <setting_list id="id_debug_settings" title="etaHEN Cheats Toolbox" second_title="Minimal cheats-only toolbox" icon="tex_etahen">
    <link id="id_cheats" title="Cheats" file="cheats.xml"/>

    <setting_list id="id_shortcuts" title="Controller Shortcuts" second_title="Shortcuts for quick cheat navigation and activation" initial_focus_to="id_cheats_shortcut">
      <list id="id_cheats_shortcut" title="Open Cheats Menu" second_title="Set a controller shortcut to open the Cheats menu from anywhere">
        <list_item id="id_cheats_shortcut_0" title="OFF (No shortcut)" value="0"/>
        <list_item id="id_cheats_shortcut_1" title="Hold R3 + L3" value="1"/>
        <list_item id="id_cheats_shortcut_2" title="Hold L2 + △" value="2"/>
        <list_item id="id_cheats_shortcut_3" title="Long Hold Options button" value="3"/>
        <list_item id="id_cheats_shortcut_4" title="Long Hold Share button" value="4"/>
        <list_item id="id_cheats_shortcut_5" title="Single Tap Share button" value="5"/>
      </list>

      <list id="id_toolbox_shortcut" title="Open Cheats Toolbox" second_title="Set a controller shortcut to open this cheats toolbox from anywhere">
        <list_item id="id_toolbox_shortcut_0" title="OFF (No shortcut)" value="0"/>
        <list_item id="id_toolbox_shortcut_1" title="Hold L2 + R3" value="1"/>
        <list_item id="id_toolbox_shortcut_2" title="Long Hold Share button" value="2"/>
        <list_item id="id_toolbox_shortcut_3" title="Single Tap Share button" value="3"/>
      </list>
    </setting_list>

    <toggle_switch id="id_toolbox_auto_start" title="Toolbox on Startup" second_title="Automatically inject cheats toolbox at startup" value="1"/>
  </setting_list>
</package>
